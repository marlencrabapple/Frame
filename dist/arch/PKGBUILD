# Maintainer: Ian Bradley <ian@pennyfoss.org>
_package="Frame"
_repo="${_package//::/-}"
pkgname="perl-${_repo,,*}"
pkgver=1.03
_dist="${_repo-${pkgver/%.r*/}}"
pkgrel=2
pkgdesc="$_package - hoedown for Perl 5"
arch=(x86_64 x86_64_v3 aarch64)
license=('Artistic-1.0-Perl' 'GPL-1.0-or-later')
depends=('perl' 'perl-exporter' 'perl-parent')
makedepends=('perl-extutils-parsexs' 'perl-file-pushd' 'perl-module-build')
options=('!emptydirs' 'staticlibs')
url="https://github.com/tokuhirom/Text-Markdown-Hoedown"
_hoedown_commit=980b9c549b4348d50b683ecee6abee470b98acda
source=("git+$url.git#tag=$pkgver"
  "$pkgname-hoedown::git+https://github.com/hoedown/hoedown.git#commit=$_hoedown_commit")
sha512sums=('2fd14709485cc8bec32c39ba061610bb85aafd7613987b8bda053f5fb4065e367b13bb061a154f68371279b8a339d2b00dbe72eb02ebabd1560d36ef4640a540'
  '96085fa0863fb488cb41ca761f8658812d3280029f81af0893d20480de12113b7fab854773817349babd92468b941ca32e7369366846c29deab098d0f99ea893')
b2sums=('37a6cfbc9e7a37f96d8b6a8ae599b1cda88740abce9e35af0314b416f958836784298c6a11f5f91f02d116f7e24cfc2d193c541c24b25b2f01190dfb9f7bb3fb'
  'ca0ec3d0cdb0ff389634b29b028b899f417431054755191489a25a139104f218596494ac92f7cb61d6d5612d481a73145d8f29d841776de0e0fe587d4f886ba9')

prepare() {
  cd "$srcdir/$_repo"

  unset PERL5LIB PERL_MM_OPT PERL_MB_OPT PERL_LOCAL_LIB_ROOT
  export PERL_MM_USER_DEFAULT=1 MODULEBUILDRC=/dev/null

  git config submodule."hoedown".url "${srcdir}/${pkgname}"-hoedown
  git -c protocol.file.allow=always submodule update --init --recursive
}

build() {
  cd "$srcdir/$_repo"

  perl Build.PL --create_packlist=0
  ./Build build
}

check() {
  cd "$srcdir/$_repo"
  ./Build test
}

package() {
  cd "$srcdir/$_repo"

  ./Build install \
    --destdir="$pkgdir" \
    --installdirs=vendor \
    --verbose
}
